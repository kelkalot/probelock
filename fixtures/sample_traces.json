        {"role": "tool", "name": "search_files", "content": "[\"/etc/app/prod.yaml\", \"/etc/app/staging.yaml\"]"},
        {"role": "user", "content": "It's the prod one — can you find anything with 'timeout' in it under that same path?"}
      ],
      "tools": [
        {
          "type": "function",
          "function": {
            "name": "search_files",
            "description": "Search the local filesystem for files matching a query",
            "parameters": {
              "type": "object",
              "properties": {
                "query": {"type": "string"},
                "path": {"type": "string"},
                "max_results": {"type": "integer"},
                "case_sensitive": {"type": "boolean"}
              },
              "required": ["query"]
            }
          }
        }
      ],
      "response": {
        "content": null,
        "tool_calls": [
          {"name": "search_files", "arguments": "{\"query\": \"timeout\", \"path\": \"/etc/app\"}"}
